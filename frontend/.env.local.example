# ── Supabase (required) ─────────────────────────────────────────────────────
# Your Supabase project URL and anon/public API key.
# Find these in your Supabase dashboard: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend API (optional — only needed for local dev) ──────────────────────
# In production, Nginx proxies /api to the Rust backend on port 8080.
# For local development, point this at your running Rust backend.
# Leave empty to use relative /api/stats (works behind Nginx proxy).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
